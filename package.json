{
  "name": "app_name",
  "version": "0.0.0",
  "private": true,
  "description": "app_description",
  "keywords": [],
  "license": "CC0-1.0",
  "author": "mizdra <pp.mizdra@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizdra/app_name.git"
  },
  "bin": {
    "example-command": "bin/example-command.js"
  },
  "files": [
    "bin",
    "src",
    "!src/**/*.test.ts",
    "!src/**/__snapshots__",
    "!src/test",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "check": "vp check",
    "dev": "vp run build && node bin/example-command.js",
    "prepare": "vp config",
    "test": "vp test"
  },
  "devDependencies": {
    "@mizdra/oxfmt-config": "^0.2.0",
    "@mizdra/oxlint-config": "^0.5.0",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.13.1",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
